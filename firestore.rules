rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    function userExists() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Helper function to check user role
    function getRole() {
      return userExists() ? 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role is string ? 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : 'student') : 
        'student';
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isStaff() {
      return isAuthenticated() && (
        getRole() == 'staff' || 
        getRole() == 'admin' || 
        getRole() == 'instructor' || 
        getRole() == 'course_manager' || 
        getRole() == 'content_creator'
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isApproved']));
      allow delete: if isAdmin();
    }

    // Site Content (Hero, etc.)
    match /siteContent/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Courses
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Enrollments
    match /enrollments/{enrollmentId} {
      allow read: if isStaff();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Contact Messages
    match /contacts/{contactId} {
      allow read: if isStaff();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Projects & Testimonials
    match /projects/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /testimonials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
